<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.myapp.controller.UserManagementController"
      spacing="0" style="-fx-background-color: #080808;">

    <!-- Top Bar -->
    <HBox style="-fx-background-color: #000000; -fx-border-color: #D4AF37; -fx-border-width: 0 0 3 0;"
          spacing="20" alignment="CENTER_LEFT">
        <padding><Insets top="14" right="30" bottom="14" left="30"/></padding>
        <Label text="✦ User Management" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #D4AF37;"/>
        <Label text="UC11: Manage All User Accounts" style="-fx-font-size: 14px; -fx-text-fill: #999999;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="↻  Refresh" styleClass="secondary-btn" onAction="#handleRefresh"/>
        <Button text="✕  Close" styleClass="outline-btn" onAction="#handleClose"/>
    </HBox>

    <!-- Page Content -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: #080808; -fx-border-color: transparent;">
        <VBox spacing="24" style="-fx-background-color: #080808;">
            <padding><Insets top="30" right="40" bottom="30" left="40"/></padding>

            <!-- Users Table -->
            <VBox spacing="14" style="-fx-background-color: #FFFFFF; -fx-background-radius: 14; -fx-border-radius: 14; -fx-border-color: #D4AF37; -fx-border-width: 2; -fx-padding: 24; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 3);">
                <Label text="All Users" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1A1A1A;"/>
                <Region prefHeight="3" maxWidth="80" style="-fx-background-color: #D4AF37;"/>
                <TableView fx:id="userTable" VBox.vgrow="ALWAYS" prefHeight="350">
                    <columns>
                        <TableColumn text="ID" fx:id="colUserId" minWidth="60" maxWidth="80"/>
                        <TableColumn text="Full Name" fx:id="colName" minWidth="180"/>
                        <TableColumn text="Email" fx:id="colEmail" minWidth="220"/>
                        <TableColumn text="Phone" fx:id="colPhone" minWidth="140"/>
                        <TableColumn text="Role" fx:id="colRole" minWidth="100"/>
                        <TableColumn text="Status" fx:id="colUserStatus" minWidth="100"/>
                    </columns>
                </TableView>
            </VBox>

            <!-- Update Status -->
            <VBox spacing="16" style="-fx-background-color: #FFFFFF; -fx-background-radius: 14; -fx-border-radius: 14; -fx-border-color: #D4AF37; -fx-border-width: 2; -fx-padding: 24;">
                <Label text="Update User Status" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1A1A1A;"/>
                <Region prefHeight="3" maxWidth="80" style="-fx-background-color: #D4AF37;"/>
                <HBox spacing="20" alignment="CENTER_LEFT">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="User ID" style="-fx-text-fill: #333333; -fx-font-weight: bold; -fx-font-size: 13px;"/>
                        <TextField fx:id="targetUserIdField" promptText="Select from table above" styleClass="text-field" prefHeight="40"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="New Status" style="-fx-text-fill: #333333; -fx-font-weight: bold; -fx-font-size: 13px;"/>
                        <ComboBox fx:id="statusCombo" styleClass="combo-box" maxWidth="Infinity" prefHeight="40"/>
                    </VBox>
                    <VBox spacing="6" alignment="BOTTOM_LEFT">
                        <Region prefHeight="19"/>
                        <Button text="⚡  UPDATE STATUS" styleClass="primary-btn" onAction="#handleUpdateStatus" prefHeight="42"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- Activity Log -->
            <VBox spacing="10" style="-fx-background-color: #111111; -fx-background-radius: 14; -fx-border-radius: 14; -fx-border-color: #333333; -fx-border-width: 1; -fx-padding: 20;">
                <Label fx:id="statusLabel" style="-fx-text-fill: #D4AF37; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                <TextArea fx:id="logArea" editable="false" prefHeight="80" styleClass="message-area" promptText="User management log..."/>
            </VBox>

        </VBox>
    </ScrollPane>
</VBox>
