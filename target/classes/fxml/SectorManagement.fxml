<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.myapp.controller.SectorManagementController"
      spacing="15" style="-fx-background-color: -fx-bg-dark;">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="15">
        <Label text="UC1: Define Sector Capacity" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: -fx-gold;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Close" styleClass="danger-btn" onAction="#handleClose"/>
    </HBox>
    <Separator/>

    <!-- Sector List -->
    <Label text="All Sectors" styleClass="label-gold"/>
    <TableView fx:id="sectorTable" prefHeight="250">
        <columns>
            <TableColumn text="ID" fx:id="colId" prefWidth="60"/>
            <TableColumn text="Sector Name" fx:id="colName" prefWidth="200"/>
            <TableColumn text="Current Capacity" fx:id="colCapacity" prefWidth="140"/>
            <TableColumn text="Property Count" fx:id="colCount" prefWidth="140"/>
            <TableColumn text="Status" fx:id="colStatus" prefWidth="120"/>
        </columns>
    </TableView>

    <!-- Update Form -->
    <VBox styleClass="card-dark" spacing="12">
        <Label text="Update Sector Capacity" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: -fx-gold;"/>
        <GridPane hgap="15" vgap="10">
            <columnConstraints>
                <ColumnConstraints percentWidth="20"/>
                <ColumnConstraints percentWidth="30"/>
                <ColumnConstraints percentWidth="20"/>
                <ColumnConstraints percentWidth="30"/>
            </columnConstraints>

            <Label text="Sector ID:" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="label-gold"/>
            <TextField fx:id="sectorIdField" promptText="Select from table" GridPane.rowIndex="0" GridPane.columnIndex="1" styleClass="text-field"/>

            <Label text="New Capacity:" GridPane.rowIndex="0" GridPane.columnIndex="2" styleClass="label-gold"/>
            <TextField fx:id="capacityField" promptText="Enter new capacity" GridPane.rowIndex="0" GridPane.columnIndex="3" styleClass="text-field"/>
        </GridPane>

        <HBox spacing="15" alignment="CENTER">
            <Button text="Update Capacity" styleClass="primary-btn" onAction="#handleUpdateCapacity"/>
            <Button text="Refresh List" styleClass="secondary-btn" onAction="#handleRefresh"/>
        </HBox>
    </VBox>

    <!-- Status -->
    <Label fx:id="statusLabel" style="-fx-text-fill: -fx-text-muted; -fx-font-size: 13px;"/>
    <TextArea fx:id="logArea" editable="false" prefHeight="120" styleClass="message-area" promptText="Activity log..."/>
</VBox>
