<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.myapp.controller.DashboardController"
      spacing="0" style="-fx-background-color: #080808;">

    <!-- Navbar -->
    <HBox styleClass="navbar" spacing="24" alignment="CENTER_LEFT">
        <Label text="✦ IRMS" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #D4AF37;"/>
        <Label text="│" style="-fx-text-fill: #444444; -fx-font-size: 22px;"/>
        <Label fx:id="userLabel" text="Welcome, User" style="-fx-text-fill: #FFFFFF; -fx-font-size: 16px; -fx-font-weight: bold;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="roleLabel" styleClass="badge-dark"/>
        <Region prefWidth="10"/>
        <Button text="✕  Logout" styleClass="outline-btn" onAction="#handleLogout"/>
    </HBox>

    <!-- Main Content Area -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: #080808; -fx-border-color: transparent;">
        <VBox spacing="30" style="-fx-background-color: #080808;">
            <padding><Insets top="45" right="50" bottom="45" left="50"/></padding>

            <!-- Welcome Section -->
            <VBox spacing="10">
                <Label fx:id="welcomeLabel" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #FFFFFF;"/>
                <Label text="Islamabad Real Estate Management System — Dashboard" style="-fx-text-fill: #D4AF37; -fx-font-size: 16px; -fx-font-weight: bold;"/>
            </VBox>

            <!-- Gold Separator -->
            <HBox maxWidth="700">
                <Region HBox.hgrow="ALWAYS" style="-fx-border-color: #D4AF37; -fx-border-width: 0 0 2 0;"/>
            </HBox>

            <Label text="⚡  Quick Actions" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #FFFFFF;"/>

            <!-- Menu Cards Grid - bigger gaps -->
            <FlowPane fx:id="menuGrid" hgap="24" vgap="24" style="-fx-background-color: transparent;"/>

        </VBox>
    </ScrollPane>
</VBox>
