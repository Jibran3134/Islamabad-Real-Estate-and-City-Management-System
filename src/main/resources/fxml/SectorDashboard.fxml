<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.myapp.controller.SectorDashboardController"
      spacing="0" style="-fx-background-color: #080808;">

    <!-- Top Bar -->
    <HBox style="-fx-background-color: #000000; -fx-border-color: #D4AF37; -fx-border-width: 0 0 3 0;"
          spacing="20" alignment="CENTER_LEFT">
        <padding><Insets top="14" right="30" bottom="14" left="30"/></padding>
        <Label text="✦ Sector Dashboard" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #D4AF37;"/>
        <Label text="UC2: Monitor &amp; Freeze Overloaded Sectors" style="-fx-font-size: 14px; -fx-text-fill: #999999;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="↻  Refresh" style="-fx-background-color: #222222; -fx-text-fill: #FFFFFF; -fx-font-weight: bold; -fx-border-color: #555555; -fx-border-width: 2; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8 18; -fx-cursor: hand;" onAction="#handleRefresh"/>
        <Button text="✕  Close"  style="-fx-background-color: transparent; -fx-text-fill: #D4AF37; -fx-border-color: #D4AF37; -fx-border-width: 2; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8 18; -fx-cursor: hand; -fx-font-weight: bold;" onAction="#handleClose"/>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: #080808; -fx-border-color: transparent;">
        <VBox spacing="24" style="-fx-background-color: #080808;">
            <padding><Insets top="30" right="40" bottom="40" left="40"/></padding>

            <!-- Statistics Table Card -->
            <VBox spacing="14" style="-fx-background-color: #FFFFFF; -fx-background-radius: 14; -fx-border-radius: 14; -fx-border-color: #D4AF37; -fx-border-width: 2; -fx-padding: 24; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.12), 10, 0, 0, 3);">
                <Label text="Sector Statistics Overview" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1A1A1A;"/>
                <Region prefHeight="3" maxWidth="80" style="-fx-background-color: #D4AF37;"/>
                <TableView fx:id="statsTable" VBox.vgrow="ALWAYS" prefHeight="280">
                    <columns>
                        <TableColumn text="ID"          fx:id="colStatId"       minWidth="55"  maxWidth="70"/>
                        <TableColumn text="Sector Name" fx:id="colStatName"     minWidth="170"/>
                        <TableColumn text="Capacity"    fx:id="colStatCapacity" minWidth="90"/>
                        <TableColumn text="Properties"  fx:id="colStatCount"    minWidth="100"/>
                        <TableColumn text="Usage %"     fx:id="colStatUsage"    minWidth="90"/>
                        <TableColumn text="Status"      fx:id="colStatStatus"   minWidth="100"/>
                        <TableColumn text="Overloaded?" fx:id="colStatOverloaded" minWidth="110"/>
                    </columns>
                </TableView>
                <Label text="💡 Click a row to auto-load Freeze Impact Analysis below" style="-fx-text-fill: #888888; -fx-font-size: 12px;"/>
            </VBox>

            <!-- Two Column: Freeze Controls (left) + NON-CRUD Impact Panel (right) -->
            <HBox spacing="24">

                <!-- Freeze Controls Card -->
                <VBox spacing="16" HBox.hgrow="ALWAYS" style="-fx-background-color: #FFFFFF; -fx-background-radius: 14; -fx-border-radius: 14; -fx-border-color: #FF4757; -fx-border-width: 2; -fx-padding: 24;">
                    <Label text="⚠  Freeze Sector" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #FF4757;"/>
                    <Region prefHeight="3" maxWidth="80" style="-fx-background-color: #FF4757;"/>

                    <VBox spacing="6">
                        <Label text="Sector ID" style="-fx-text-fill: #1A1A1A; -fx-font-weight: bold; -fx-font-size: 13px;"/>
                        <TextField fx:id="freezeSectorIdField" promptText="Click a row above to select"
                                   style="-fx-background-color: #FFFFFF; -fx-text-fill: #111111; -fx-border-color: #CCCCCC; -fx-border-width: 2; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10 14; -fx-font-size: 14px;"
                                   prefHeight="40"/>
                    </VBox>

                    <CheckBox fx:id="overrideCheckbox" text="Override Warning (force freeze non-overloaded sector)"
                              style="-fx-text-fill: #1A1A1A; -fx-font-size: 13px;"/>

                    <VBox spacing="10">
                        <Button text="🔍  Analyze Impact First"
                                onAction="#handleAnalyzeImpact"
                                prefHeight="42" maxWidth="Infinity"
                                style="-fx-background-color: #222222; -fx-text-fill: #FFFFFF; -fx-font-weight: bold; -fx-font-size: 14px; -fx-border-color: #D4AF37; -fx-border-width: 2; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 10 20; -fx-cursor: hand;"/>
                        <Button text="🔒  FREEZE SECTOR"
                                onAction="#handleFreezeSector"
                                prefHeight="46" maxWidth="Infinity"
                                style="-fx-background-color: #FF4757; -fx-text-fill: #FFFFFF; -fx-font-weight: bold; -fx-font-size: 15px; -fx-border-color: #FF6B7A; -fx-border-width: 2; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12 20; -fx-cursor: hand;"/>
                    </VBox>
                </VBox>

                <!-- NON-CRUD: Freeze Impact Analysis Panel -->
                <VBox spacing="14" HBox.hgrow="ALWAYS" style="-fx-background-color: #0D0D0D; -fx-background-radius: 14; -fx-border-radius: 14; -fx-border-color: #FF4757; -fx-border-width: 2; -fx-padding: 24;">
                    <Label text="📊 Freeze Impact Analysis" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #FF4757;"/>
                    <Label text="NON-CRUD: Calculates impact BEFORE freeze executes" style="-fx-font-size: 12px; -fx-text-fill: #777777;"/>
                    <Region prefHeight="2" maxWidth="200" style="-fx-background-color: #FF4757;"/>

                    <VBox spacing="8">
                        <Label fx:id="impactSeverityLabel"
                               text="Impact: — (select a sector row)"
                               style="-fx-text-fill: #AAAAAA; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                        <Label fx:id="impactSummaryLabel"
                               text="🚫 listings blocked  |  🔨 auctions affected"
                               style="-fx-text-fill: #888888; -fx-font-size: 13px;"/>
                    </VBox>

                    <TextArea fx:id="impactTextArea" editable="false" prefHeight="160"
                              promptText="Select a sector row or click 'Analyze Impact' to see:&#10;• Number of listings that will be blocked&#10;• Total PKR value at risk&#10;• Active auctions disrupted&#10;• Severity score (0-100)"
                              style="-fx-background-color: #1A1A1A; -fx-text-fill: #CCCCCC; -fx-border-color: #333333; -fx-font-size: 12px; -fx-background-radius: 8;"/>
                </VBox>
            </HBox>

            <!-- Status + Log -->
            <VBox spacing="10" style="-fx-background-color: #111111; -fx-background-radius: 14; -fx-border-radius: 14; -fx-border-color: #333333; -fx-border-width: 1; -fx-padding: 20;">
                <Label fx:id="statusLabel" text="" style="-fx-text-fill: #D4AF37; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                <TextArea fx:id="logArea" editable="false" prefHeight="100"
                          style="-fx-background-color: #111111; -fx-text-fill: #AAAAAA; -fx-border-color: #D4AF37; -fx-border-width: 2; -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-family: 'Consolas'; -fx-font-size: 12px;"
                          promptText="Activity log..."/>
            </VBox>

        </VBox>
    </ScrollPane>
</VBox>
