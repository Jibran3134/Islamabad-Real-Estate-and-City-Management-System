<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.myapp.controller.BiddingDashboardController"
      spacing="0" style="-fx-background-color: #080808;">

    <!-- Top Bar -->
    <HBox style="-fx-background-color: #000000; -fx-border-color: #D4AF37; -fx-border-width: 0 0 3 0;"
          spacing="20" alignment="CENTER_LEFT">
        <padding><Insets top="14" right="30" bottom="14" left="30"/></padding>
        <Label text="✦ Bidding Dashboard" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #D4AF37;"/>
        <Label text="UC6-9: Auction Management" style="-fx-font-size: 14px; -fx-text-fill: #999999;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="↻  Refresh" styleClass="secondary-btn" onAction="#handleRefresh"/>
        <Button text="✕  Close" styleClass="outline-btn" onAction="#handleClose"/>
    </HBox>

    <!-- Page Content -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: #080808; -fx-border-color: transparent;">
        <VBox spacing="24" style="-fx-background-color: #080808;">
            <padding><Insets top="30" right="40" bottom="30" left="40"/></padding>

            <!-- Active Sessions Table -->
            <VBox spacing="14" style="-fx-background-color: #FFFFFF; -fx-background-radius: 14; -fx-border-radius: 14; -fx-border-color: #D4AF37; -fx-border-width: 2; -fx-padding: 24; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 3);">
                <Label text="Active Bidding Sessions" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1A1A1A;"/>
                <Region prefHeight="3" maxWidth="80" style="-fx-background-color: #D4AF37;"/>
                <TableView fx:id="sessionTable" VBox.vgrow="ALWAYS" prefHeight="240">
                    <columns>
                        <TableColumn text="Session ID" fx:id="colSessionId" minWidth="90"/>
                        <TableColumn text="Property" fx:id="colProperty" minWidth="200"/>
                        <TableColumn text="Base Price" fx:id="colBasePrice" minWidth="130"/>
                        <TableColumn text="Highest Bid" fx:id="colHighestBid" minWidth="130"/>
                        <TableColumn text="Status" fx:id="colSessionStatus" minWidth="100"/>
                        <TableColumn text="End Time" fx:id="colEndTime" minWidth="150"/>
                    </columns>
                </TableView>
            </VBox>

            <!-- Place Bid Section -->
            <VBox spacing="16" style="-fx-background-color: #FFFFFF; -fx-background-radius: 14; -fx-border-radius: 14; -fx-border-color: #2ED573; -fx-border-width: 2; -fx-padding: 24;">
                <Label text="💰  Place a Bid (UC6)" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1A1A1A;"/>
                <Region prefHeight="3" maxWidth="80" style="-fx-background-color: #2ED573;"/>
                <HBox spacing="20" alignment="CENTER_LEFT">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Session ID" style="-fx-text-fill: #333333; -fx-font-weight: bold; -fx-font-size: 13px;"/>
                        <TextField fx:id="sessionIdField" promptText="Select from table above" styleClass="text-field" prefHeight="40"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Bid Amount (PKR)" style="-fx-text-fill: #333333; -fx-font-weight: bold; -fx-font-size: 13px;"/>
                        <TextField fx:id="bidAmountField" promptText="Enter your bid amount" styleClass="text-field" prefHeight="40"/>
                    </VBox>
                    <VBox spacing="6" alignment="BOTTOM_LEFT">
                        <Region prefHeight="19"/>
                        <Button text="⚡  PLACE BID" styleClass="primary-btn" onAction="#handlePlaceBid" prefHeight="42"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- Close & Declare Winner - Side by Side -->
            <HBox spacing="24">
                <!-- UC8: Close Bidding -->
                <VBox spacing="14" HBox.hgrow="ALWAYS" style="-fx-background-color: #FFFFFF; -fx-background-radius: 14; -fx-border-radius: 14; -fx-border-color: #FF4757; -fx-border-width: 2; -fx-padding: 24;">
                    <Label text="🔒  Close Bidding (UC8)" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1A1A1A;"/>
                    <Region prefHeight="3" maxWidth="60" style="-fx-background-color: #FF4757;"/>
                    <VBox spacing="6">
                        <Label text="Session ID" style="-fx-text-fill: #333333; -fx-font-weight: bold; -fx-font-size: 13px;"/>
                        <TextField fx:id="closeSessionIdField" promptText="Enter Session ID" styleClass="text-field" prefHeight="40"/>
                    </VBox>
                    <Button text="🔒  CLOSE SESSION" styleClass="danger-btn" onAction="#handleCloseBidding" prefHeight="42" maxWidth="Infinity"/>
                </VBox>

                <!-- UC9: Declare Winner -->
                <VBox spacing="14" HBox.hgrow="ALWAYS" style="-fx-background-color: #FFFFFF; -fx-background-radius: 14; -fx-border-radius: 14; -fx-border-color: #2ED573; -fx-border-width: 2; -fx-padding: 24;">
                    <Label text="🏆  Declare Winner (UC9)" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1A1A1A;"/>
                    <Region prefHeight="3" maxWidth="60" style="-fx-background-color: #2ED573;"/>
                    <VBox spacing="6">
                        <Label text="Session ID" style="-fx-text-fill: #333333; -fx-font-weight: bold; -fx-font-size: 13px;"/>
                        <TextField fx:id="winnerSessionIdField" promptText="Enter Session ID" styleClass="text-field" prefHeight="40"/>
                    </VBox>
                    <Button text="🏆  DECLARE WINNER" styleClass="success-btn" onAction="#handleDeclareWinner" prefHeight="42" maxWidth="Infinity"/>
                </VBox>
            </HBox>

            <!-- Activity Log -->
            <VBox spacing="10" style="-fx-background-color: #111111; -fx-background-radius: 14; -fx-border-radius: 14; -fx-border-color: #333333; -fx-border-width: 1; -fx-padding: 20;">
                <Label fx:id="statusLabel" style="-fx-text-fill: #D4AF37; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                <TextArea fx:id="logArea" editable="false" prefHeight="80" styleClass="message-area" promptText="Bidding activity log..."/>
            </VBox>

        </VBox>
    </ScrollPane>
</VBox>
