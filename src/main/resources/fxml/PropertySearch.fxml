<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.myapp.controller.PropertySearchViewController"
      spacing="0" style="-fx-background-color: #080808;">

    <!-- Top Bar -->
    <HBox style="-fx-background-color: #000000; -fx-border-color: #D4AF37; -fx-border-width: 0 0 3 0;"
          spacing="20" alignment="CENTER_LEFT">
        <padding><Insets top="14" right="30" bottom="14" left="30"/></padding>
        <Label text="✦ Property Search" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #D4AF37;"/>
        <Label text="UC4: Search with Ranking (NON-CRUD)" style="-fx-font-size: 14px; -fx-text-fill: #999999;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="✕  Close" styleClass="outline-btn" onAction="#handleClose"/>
    </HBox>

    <!-- Page Content -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: #080808; -fx-border-color: transparent;">
        <VBox spacing="24" style="-fx-background-color: #080808;">
            <padding><Insets top="30" right="40" bottom="30" left="40"/></padding>

            <!-- Search Filters Card -->
            <VBox spacing="18" style="-fx-background-color: #FFFFFF; -fx-background-radius: 14; -fx-border-radius: 14; -fx-border-color: #D4AF37; -fx-border-width: 2; -fx-padding: 24; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 3);">
                <Label text="Search Filters" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1A1A1A;"/>
                <Region prefHeight="3" maxWidth="80" style="-fx-background-color: #D4AF37;"/>

                <!-- Row 1 -->
                <HBox spacing="20">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Location" style="-fx-text-fill: #1A1A1A; -fx-font-weight: bold; -fx-font-size: 13px;"/>
                        <TextField fx:id="locationField" promptText="Street, City, etc." styleClass="text-field" prefHeight="40"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Sector" style="-fx-text-fill: #1A1A1A; -fx-font-weight: bold; -fx-font-size: 13px;"/>
                        <ComboBox fx:id="sectorCombo" styleClass="combo-box" maxWidth="Infinity" prefHeight="40"/>
                    </VBox>
                </HBox>

                <!-- Row 2 -->
                <HBox spacing="20">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Min Price (PKR)" style="-fx-text-fill: #1A1A1A; -fx-font-weight: bold; -fx-font-size: 13px;"/>
                        <TextField fx:id="minPriceField" promptText="Minimum price" styleClass="text-field" prefHeight="40"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Max Price (PKR)" style="-fx-text-fill: #1A1A1A; -fx-font-weight: bold; -fx-font-size: 13px;"/>
                        <TextField fx:id="maxPriceField" promptText="Maximum price" styleClass="text-field" prefHeight="40"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Property Type" style="-fx-text-fill: #1A1A1A; -fx-font-weight: bold; -fx-font-size: 13px;"/>
                        <ComboBox fx:id="typeCombo" styleClass="combo-box" maxWidth="Infinity" prefHeight="40"/>
                    </VBox>
                </HBox>

                <!-- Buttons -->
                <HBox spacing="16" alignment="CENTER_LEFT">
                    <Button text="🔍  SEARCH" styleClass="primary-btn" onAction="#handleSearch" prefHeight="42" prefWidth="150"/>
                    <Button text="Clear Filters" styleClass="secondary-btn" onAction="#handleClearFilters" prefHeight="42"/>
                    <Button text="Refresh" styleClass="outline-btn" onAction="#handleReset" prefHeight="42"/>
                </HBox>
            </VBox>

            <!-- Results -->
            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label fx:id="resultsLabel" style="-fx-text-fill: #D4AF37; -fx-font-weight: bold; -fx-font-size: 16px;"/>
            </HBox>

            <!-- Results Table -->
            <VBox spacing="10" style="-fx-background-color: #FFFFFF; -fx-background-radius: 14; -fx-border-radius: 14; -fx-border-color: #D4AF37; -fx-border-width: 2; -fx-padding: 20;">
                <TableView fx:id="resultsTable" VBox.vgrow="ALWAYS" prefHeight="280">
                    <columns>
                        <TableColumn text="RANK" fx:id="colRank" minWidth="60" maxWidth="80"/>
                        <TableColumn text="SCORE" fx:id="colScore" minWidth="70" maxWidth="90"/>
                        <TableColumn text="TITLE" fx:id="colTitle" minWidth="200"/>
                        <TableColumn text="LOCATION" fx:id="colLocation" minWidth="140"/>
                        <TableColumn text="PRICE (PKR)" fx:id="colPrice" minWidth="130"/>
                        <TableColumn text="TYPE" fx:id="colType" minWidth="110"/>
                        <TableColumn text="SECTOR" fx:id="colSector" minWidth="70"/>
                    </columns>
                </TableView>
            </VBox>

            <!-- Ranking Info -->
            <VBox spacing="6" style="-fx-background-color: #111111; -fx-background-radius: 14; -fx-border-radius: 14; -fx-border-color: #333333; -fx-border-width: 1; -fx-padding: 18;">
                <Label text="Ranking Formula (NON-CRUD Operation)" style="-fx-font-weight: bold; -fx-text-fill: #D4AF37; -fx-font-size: 14px;"/>
                <Label text="Score = (Matched Filters) × 10  |  Location: +10  |  Price: +10  |  Type: +10  |  Sector: +10  |  Max: 40/40"
                       style="-fx-text-fill: #CCCCCC; -fx-font-size: 13px;"/>
                <Label fx:id="rankingInfoLabel" style="-fx-text-fill: #999999; -fx-font-size: 12px;"/>
            </VBox>

            <!-- Log -->
            <TextArea fx:id="messageArea" editable="false" prefHeight="70" styleClass="message-area" promptText="System messages..."/>

        </VBox>
    </ScrollPane>
</VBox>
